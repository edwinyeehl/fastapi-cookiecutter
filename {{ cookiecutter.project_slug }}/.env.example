# Environment Configuration Example for {{ cookiecutter.project_name }}

# App Settings
APP_ENV=local
DEBUG=true
SECRET_KEY=generate-a-secure-secret-key-for-jwt-token-signing

# --- Database Configuration ---
# Target Database: 'mssql' (main) or 'postgresql' (supporting)
DB_DIALECT=mssql

# --- SQL Server (Main) Settings ---
# Example connection string for SQL Server using aioodbc (async)
# Make sure the ODBC Driver for SQL Server is installed on your host system.
DATABASE_URL=mssql+aioodbc://sa:DevPassword@123!@localhost:1433/{{ cookiecutter.project_slug }}?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes

# SQL Server credentials
MSSQL_SA_PASSWORD=DevPassword@123!

# --- PostgreSQL (Supporting) Settings ---
# Example connection string for PostgreSQL using asyncpg
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/{{ cookiecutter.project_slug }}
